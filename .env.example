# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
# Or use other LLM providers
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Browser
HEADLESS=true
SLOW_MO=0
BROWSER_TIMEOUT=30000

# Database
DATABASE_URL=sqlite:///./ariadne.db
# For Postgres: postgresql://user:password@localhost:5432/ariadne

# Artifacts
SCREENSHOTS_DIR=./artifacts/screenshots
TRACES_DIR=./artifacts/traces
